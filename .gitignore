# .gitignore

# -----------------
# SECRETS (CRITICAL)
# -----------------
.env

# -----------------
# TERRAFORM
# -----------------
# Local .terraform directories
**/.terraform/*

# .tfstate files (CRITICAL: These contain your AWS infrastructure in plain text!)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -----------------
# PYTHON
# -----------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
ENV/

# -----------------
# OS GENERATED
# -----------------
.DS_Store
Thumbs.db
terraform/.terraform.lock.hcl
